<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.serve.mapper.ArticleLabelMapper">
    <select id="queryLabelByArticleId" resultType="com.serve.po.Label">
        select tag_id as id, name
        from blog.article_tag left outer join blog.tag on article_tag.tag_id = tag.id
        <where>
            article_id = #{articleId}
        </where>
    </select>
</mapper>